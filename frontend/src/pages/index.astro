---
/**
 * Homepage — legge il contenuto dalla collezione singleton "homepage" di Directus.
 *
 * Per modificare il contenuto: aprire Directus (http://localhost:8055),
 * cliccare su "Homepage" nella sidebar, modificare i campi, salvare.
 * Ricaricare questa pagina per vedere le modifiche.
 */

import Base from "../layouts/Base.astro";
import { directus, assetUrl } from "../lib/directus";
import { readSingleton } from "@directus/sdk";
import { marked } from "marked";

let homepage;
let error;

try {
  homepage = await directus.request(readSingleton("homepage"));
} catch (e) {
  error = e instanceof Error ? e.message : "Errore di connessione a Directus";
}
---

<Base title={homepage?.titolo_sito ?? "Home"}>
  {
    error ? (
      <section class="error">
        <h1>⚠️ Directus non raggiungibile</h1>
        <p>Verifica che i container siano avviati:</p>
        <pre><code>docker compose up -d</code></pre>
        <p>
          Poi esegui lo script di setup se è il primo avvio:
        </p>
        <pre><code>node scripts/setup.mjs</code></pre>
        <details>
          <summary>Dettaglio errore</summary>
          <pre>{error}</pre>
        </details>
      </section>
    ) : (
      <section class="hero">
        <div class="hero-image-container">
          {homepage.immagine_hero && (
            <img src={assetUrl(homepage.immagine_hero)} alt="" class="hero-img" />
          )}
          <div class="hero-overlay" />
          <div class="hero-content">
            <h1>{homepage.titolo_sito}</h1>
            <p class="subtitle">{homepage.sottotitolo}</p>
          </div>
        </div>
        <div class="description-wrapper">
          <div class="description" set:html={marked.parse(homepage.descrizione ?? "")} />
        </div>
      </section>
    )
  }
</Base>

<style>
  .hero {
    padding: 0;
    margin: 0;
  }

  .hero-image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.6) 50%,
      rgba(0, 0, 0, 0.7) 100%
    );
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    text-align: center;
    color: white;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin: 0 0 1rem 0;
    line-height: 1.2;
    text-shadow:
      0 2px 4px rgba(0, 0, 0, 0.9),
      0 4px 12px rgba(0, 0, 0, 0.7),
      0 8px 24px rgba(0, 0, 0, 0.5);
  }

  .subtitle {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    margin: 0;
    opacity: 0.95;
    text-shadow:
      0 2px 4px rgba(0, 0, 0, 0.9),
      0 4px 12px rgba(0, 0, 0, 0.6);
    max-width: 600px;
  }

  .description-wrapper {
    background: #f9fafb;
    padding: 4rem 2rem;
  }

  .description {
    max-width: 640px;
    margin-inline: auto;
    text-align: left;
    line-height: 1.8;
    color: #374151;
  }

  .description :global(h1),
  .description :global(h2),
  .description :global(h3),
  .description :global(h4) {
    color: #111827;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-weight: 700;
  }

  .description :global(h1) { font-size: 1.75rem; }
  .description :global(h2) { font-size: 1.5rem; }
  .description :global(h3) { font-size: 1.25rem; }

  .description :global(p) {
    margin-bottom: 1em;
  }

  .description :global(a) {
    color: #2563eb;
    text-decoration: underline;
  }

  .description :global(a:hover) {
    opacity: 0.8;
  }

  .description :global(strong) {
    font-weight: 700;
    color: #111827;
  }

  .description :global(em) {
    font-style: italic;
  }

  .description :global(ul),
  .description :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1em;
  }

  .description :global(li) {
    margin-bottom: 0.25em;
  }

  .description :global(blockquote) {
    border-left: 4px solid #2563eb;
    margin: 1em 0;
    padding: 0.5em 1em;
    background: #eff6ff;
    border-radius: 0 6px 6px 0;
    color: #1e40af;
  }

  .description :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: #f3f4f6;
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .description :global(pre) {
    background: #1f2937;
    color: #d4d4d4;
    padding: 1em;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1em;
  }

  .description :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .description :global(hr) {
    border: none;
    border-top: 2px solid #e5e7eb;
    margin: 2em 0;
  }

  .description :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1em 0;
  }

  .error {
    padding-block: 3rem;
  }

  .error h1 {
    margin-bottom: 1rem;
  }

  .error pre {
    background: #f3f4f6;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    margin-block: 0.5rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    overflow-x: auto;
  }

  details {
    margin-top: 1rem;
    color: var(--color-muted);
    font-size: 0.875rem;
  }
</style>
