# URL del backend Directus per le chiamate API server-side.
# Quando il frontend gira nel container Docker, questo valore
# viene sovrascritto dalla variabile nel compose.yml (http://directus:8055).
DIRECTUS_URL=http://localhost:8055

# URL pubblico di Directus per i riferimenti nel browser (immagini, link).
# Il prefisso PUBLIC_ lo rende disponibile anche nel codice client-side.
# Questo deve sempre puntare a localhost perché il browser dell'utente
# non può raggiungere la rete interna Docker.
PUBLIC_DIRECTUS_URL=http://localhost:8055
